---
// index.astro — evanjohnson.ca homepage
// Professional black · dark red accent · Michroma + DM Mono
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="Evan Johnson — Chemical Engineering Student, Student Project Coordinator at Graham Construction, 3× Hackathon Winner." />
  <title>Evan Johnson</title>
  <link href="https://fonts.googleapis.com/css2?family=Michroma&family=Exo+2:wght@300;400;500;600&family=DM+Mono:wght@300;400&display=swap" rel="stylesheet" />
  <style>
    /* ── RESET ── */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body { font-family: 'Exo 2', sans-serif; background: #0a0a0a; color: #e8e8e8; }

    /* ── CSS VARIABLES ── */
    :root {
      --black:      #0a0a0a;
      --black-2:    #080808;
      --black-3:    #060606;
      --surface-1:  #111111;
      --surface-2:  #161616;
      --surface-3:  #1e1e1e;
      --border-1:   #141414;
      --border-2:   #1e1e1e;
      --text-1:     #e8e8e8;
      --text-2:     #bbb;
      --text-3:     #555;
      --text-4:     #333;
      --text-5:     #222;
      --red:        #8b0000;
      --red-light:  #a00000;
    }

    /* ── NAV ── */
    .nav {
      background: var(--black);
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0 60px;
      height: 64px;
      border-bottom: 1px solid var(--border-2);
      position: sticky;
      top: 0;
      z-index: 100;
    }
    .nav-logo {
      font-family: 'Michroma', monospace;
      font-size: 15px;
      color: var(--text-1);
      letter-spacing: 0.06em;
      text-decoration: none;
    }
    .nav-links { display: flex; gap: 40px; list-style: none; }
    .nav-links a {
      font-family: 'DM Mono', monospace;
      font-size: 10px;
      font-weight: 300;
      color: var(--text-3);
      letter-spacing: 0.18em;
      text-decoration: none;
      text-transform: uppercase;
      transition: color 0.2s ease;
    }
    .nav-links a:hover { color: var(--text-1); }

    /* ── HERO ── */
    .hero {
      background: var(--black);
      padding: 100px 60px 80px;
      min-height: 89vh;
      justify-content: center;
      display: flex;
      flex-direction: column;
      align-items: center;
      text-align: center;
      border-bottom: 1px solid var(--border-2);
      position: relative;
      overflow: hidden;
    }
    .hero-grid {
      position: absolute;
      inset: 0;
      background-image:
          linear-gradient(var(--surface-2) 1px, transparent 1px),
          linear-gradient(90deg, var(--surface-2) 1px, transparent 1px);
      background-size: 60px 60px;
      opacity: 0.6;
      pointer-events: none;
    }
    .hero-grid-fade {
      position: absolute;
      inset: 0;
      background: radial-gradient(ellipse at center, transparent 30%, var(--black) 75%);
      pointer-events: none;
    }
    .hero-eyebrow {
      font-family: 'DM Mono', monospace;
      font-size: 10px;
      font-weight: 300;
      letter-spacing: 0.3em;
      text-transform: uppercase;
      color: var(--text-4);
      margin-bottom: 40px;
      position: relative;
      z-index: 2;
    }
    .hero-name {
      font-family: 'Michroma', monospace;
      font-size: clamp(64px, 9vw, 260px);
      color: var(--text-1);
      line-height: 0.88;
      letter-spacing: -0.02em;
      position: relative;
      z-index: 2;
      margin-bottom: 220px;
    }
    .hero-name span { display: block; }
    .hero-rule {
      width: 100%;
      max-width: 1260px;
      height: 1px;
      background: var(--border-2);
      margin: 0 auto 36px;
      position: relative;
      z-index: 2;
    }
    .hero-rule::after {
      content: '';
      position: absolute;
      left: 50.2%;
      top: 50%;
      transform: translate(-50%, -50%);
      width: 5px;
      height: 5px;
      background: var(--red);
    }
    .hero-titles {
      display: flex;
      align-items: center;
      justify-content: center;
      flex-wrap: wrap;
      gap: 0;
      margin-bottom: 48px;
      position: relative;
      z-index: 2;
    }
    .title-item {
      font-family: 'Exo 2', sans-serif;
      font-size: clamp(11px, 1.3vw, 16px);
      font-weight: 500;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--text-3);
      padding: 0 24px;
      position: relative;
      white-space: nowrap;
    }
    .title-item::after {
      content: '';
      position: absolute;
      right: 0;
      top: 50%;
      transform: translateY(-50%);
      width: 1px;
      height: 12px;
      background: #222;
    }
    .title-item:last-child::after { display: none; }
    .title-item.bright { color: var(--text-1); }
    .title-item.red    { color: var(--red); }

    /* ── BUTTONS ── */
    .hero-actions {
      display: flex;
      gap: 12px;
      position: relative;
      z-index: 2;
      flex-wrap: wrap;
      justify-content: center;
    }
    .btn {
      font-family: 'DM Mono', monospace;
      font-size: 10px;
      font-weight: 300;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      padding: 12px 28px;
      cursor: pointer;
      border: 1px solid #222;
      color: var(--text-3);
      background: transparent;
      text-decoration: none;
      transition: border-color 0.2s, color 0.2s, background 0.2s;
    }
    .btn:hover { border-color: #444; color: var(--text-1); }
    .btn.primary { border-color: var(--red); color: var(--red); }
    .btn.primary:hover { background: var(--red); color: var(--text-1); }

    /* ── STATS BAR ── */
    .stats-bar {
      background: var(--black-2);
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      border-bottom: 1px solid var(--border-1);
    }
    .stat-cell {
      padding: 32px 40px;
      border-right: 1px solid var(--border-1);
      text-align: center;
    }
    .stat-cell:last-child { border-right: none; }
    .stat-num {
      font-family: 'Michroma', monospace;
      font-size: 32px;
      color: var(--text-1);
      line-height: 1;
      margin-bottom: 8px;
    }
    .stat-num.red { color: var(--red); }
    .stat-lbl {
      font-family: 'DM Mono', monospace;
      font-size: 9px;
      color: var(--text-5);
      letter-spacing: 0.2em;
      text-transform: uppercase;
      font-weight: 300;
    }

    /* ── CONTENT GRID ── */
    .content {
      background: var(--black);
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      border-top: 1px solid var(--surface-2);
    }
    .panel {
      padding: 36px 32px;
      border-right: 1px solid var(--border-1);
    }
    .panel:last-child { border-right: none; }
    .panel-label {
      font-family: 'DM Mono', monospace;
      font-size: 9px;
      font-weight: 300;
      letter-spacing: 0.24em;
      text-transform: uppercase;
      color: var(--text-5);
      margin-bottom: 24px;
      padding-bottom: 16px;
      border-bottom: 1px solid var(--surface-2);
    }

    /* Projects */
    .hack-list { display: flex; flex-direction: column; gap: 14px; }
    .hack-item {
      display: flex;
      flex-direction: column;
      gap: 3px;
      padding-bottom: 14px;
      border-bottom: 1px solid var(--surface-1);
    }
    .hack-item:last-child { border-bottom: none; padding-bottom: 0; }
    .hack-top { display: flex; align-items: baseline; gap: 10px; }
    .hack-rank {
      font-family: 'Michroma', monospace;
      font-size: 10px;
      color: var(--red);
      min-width: 16px;
    }
    .hack-name { font-size: 12px; color: var(--text-2); font-weight: 400; letter-spacing: 0.04em; }
    .hack-pos {
      font-family: 'DM Mono', monospace;
      font-size: 9px;
      color: var(--text-5);
      margin-left: auto;
      letter-spacing: 0.1em;
      white-space: nowrap;
    }
    .hack-sub {
      font-family: 'DM Mono', monospace;
      font-size: 9px;
      color: #1e1e1e;
      padding-left: 26px;
      letter-spacing: 0.08em;
    }

    /* About */
    .about-text { font-size: 12px; color: #4a4a4a; line-height: 1.9; font-weight: 300; }
    .about-text strong { color: #888; font-weight: 400; }

    /* Skills */
    .skill-list { display: flex; flex-direction: column; gap: 6px; }
    .skill {
      font-family: 'DM Mono', monospace;
      font-size: 10px;
      color: var(--text-4);
      padding: 8px 12px;
      border: 1px solid var(--surface-1);
      letter-spacing: 0.08em;
      font-weight: 300;
      transition: color 0.2s, border-color 0.2s;
    }
    .skill:hover { color: var(--text-2); border-color: #2a2a2a; }

    /* Experience */
    .exp-list { display: flex; flex-direction: column; gap: 16px; }
    .exp-item {
      padding-bottom: 16px;
      border-bottom: 1px solid var(--surface-1);
    }
    .exp-item:last-child { border-bottom: none; padding-bottom: 0; }
    .exp-title  { font-size: 12px; color: var(--text-2); font-weight: 400; margin-bottom: 3px; letter-spacing: 0.04em; }
    .exp-company { font-size: 11px; color: #3a3a3a; margin-bottom: 4px; }
    .exp-date   { font-family: 'DM Mono', monospace; font-size: 9px; color: var(--text-5); letter-spacing: 0.1em; }

    /* ── FOOTER ── */
    .footer {
      background: var(--black-3);
      padding: 24px 60px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      border-top: 1px solid var(--surface-2);
    }
    .footer-name { font-family: 'Michroma', monospace; font-size: 13px; color: #2a2a2a; letter-spacing: 0.06em; }
    .footer-links { display: flex; gap: 32px; }
    .footer-link {
      font-family: 'DM Mono', monospace;
      font-size: 9px;
      color: var(--text-5);
      letter-spacing: 0.14em;
      text-transform: uppercase;
      text-decoration: none;
      transition: color 0.2s;
    }
    .footer-link:hover { color: var(--text-3); }
    .footer-loc { font-family: 'DM Mono', monospace; font-size: 9px; color: #1a1a1a; letter-spacing: 0.1em; }

    /* ── RESPONSIVE ── */
    @media (max-width: 1024px) {
      .nav { padding: 0 32px; }
      .hero { padding: 60px 32px 48px; }
      .stats-bar { grid-template-columns: repeat(2, 1fr); }
      .stat-cell:nth-child(2) { border-right: none; }
      .content { grid-template-columns: repeat(2, 1fr); }
      .panel:nth-child(even) { border-right: none; }
      .footer { padding: 20px 32px; flex-wrap: wrap; gap: 12px; }
    }

    @media (max-width: 640px) {
      .nav { padding: 0 20px; }
      .nav-links { gap: 20px; }
      .hero { padding: 48px 20px 40px; }
      .title-item { padding: 0 12px; font-size: 11px; }
      .stats-bar { grid-template-columns: repeat(2, 1fr); }
      .content { grid-template-columns: 1fr; }
      .panel { border-right: none; border-bottom: 1px solid var(--border-1); }
      .panel:last-child { border-bottom: none; }
      .footer { flex-direction: column; align-items: flex-start; padding: 20px; gap: 10px; }
    }
  </style>
</head>

<body>

<!-- NAV -->
<nav class="nav">
  <a href="/" class="nav-logo">Evan Johnson</a>
  <ul class="nav-links">
    <li><a href="#about">About</a></li>
    <li><a href="#projects">Projects</a></li>
    <li><a href="#experience">Experience</a></li>
    <li><a href="#skills">Skills</a></li>
    <li><a href="#contact">Contact</a></li>
  </ul>
</nav>

<!-- HERO -->
<section class="hero">
  <div class="hero-grid"></div>
  <div class="hero-grid-fade"></div>

  <p class="hero-eyebrow">Chemical Engineering · University of Saskatchewan · 2nd Year</p>

  <h1 class="hero-name">
    <span>Evan</span>
    <span>Johnson</span>
  </h1>

  <div class="hero-rule"></div>

  <div class="hero-titles">
    <span class="title-item bright">Graham Construction</span>
    <span class="title-item">Student Project Coordinator</span>
    <span class="title-item red">3× Hackathon Winner</span>
    <span class="title-item">Nuclear Industry</span>
    <span class="title-item">Saskatoon, SK</span>
  </div>

  <div class="hero-actions">
    <a href="/resume.pdf" class="btn primary" target="_blank">View Resume</a>
    <a href="#contact" class="btn">Get in Touch</a>
    <a href="https://www.linkedin.com/in/evan-johnson-sk" class="btn" target="_blank">LinkedIn</a>
  </div>
</section>


<!-- FOOTER -->
<footer class="footer" id="contact">
  <span class="footer-name">Evan Johnson</span>
  <div class="footer-links">
    <a href="https://www.linkedin.com/in/evan-johnson-sk" class="footer-link" target="_blank">LinkedIn</a>
    <a href="mailto:evanjohnson295@gmail.com" class="footer-link">evanjohnson295@gmail.com</a>
    <a href="https://evanjohnson.ca" class="footer-link">evanjohnson.ca</a>
  </div>
  <span class="footer-loc">Saskatoon, Saskatchewan</span>
</footer>

</body>
</html>