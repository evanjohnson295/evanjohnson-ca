---
// index.astro — evanjohnson.ca homepage
// How to Update:
// git add .
// git commit -m "Information about the Update"
// git push
import Layout from '../layouts/Layout.astro';
---

<Layout
    title="Evan Johnson"
    description="Evan Johnson — Chemical Engineering Student, Student Project Coordinator at Graham Construction, 3× Hackathon Winner."
    activePage=""
>

  <style>
    .hero {
      padding: 0 60px 0;
      height: calc(95vh - 64px - 70px);
      justify-content: center;
      display: flex;
      flex-direction: column;
      align-items: center;
      text-align: center;
      border-bottom: 1px solid var(--border-2);
      position: relative;
      overflow: hidden;
    }
    .hero-eyebrow {
      font-family: 'DM Mono', monospace;
      font-size: 14px;
      font-weight: 300;
      letter-spacing: 0.3em;
      text-transform: uppercase;
      color: var(--text-4);
      margin-bottom: 0;
      position: relative;
      z-index: 2;
    }
    .hero-name {
      font-family: 'Michroma', monospace;
      font-size: clamp(64px, 9vw, 260px);
      color: var(--text-1);
      line-height: 0.88;
      letter-spacing: -0.02em;
      position: relative;
      z-index: 2;
      margin-bottom: 8vh;
    }
    .hero-name span { display: block; }
    .hero-rule {
      width: 100%;
      max-width: 1260px;
      height: 1px;
      background: var(--border-2);
      margin: 0 auto 36px;
      position: relative;
      z-index: 2;
    }
    .hero-rule::after {
      content: '';
      position: absolute;
      left: 50.4%;
      top: 50%;
      transform: translate(-50%, -50%);
      width: 5px;
      height: 5px;
      background: var(--red);
    }
    .hero-titles {
      display: flex;
      align-items: center;
      justify-content: center;
      flex-wrap: wrap;
      gap: 0;
      margin-bottom: 48px;
      position: relative;
      z-index: 2;
    }
    .title-item {
      font-family: 'Exo 2', sans-serif;
      font-size: clamp(11px, 1.3vw, 16px);
      font-weight: 500;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--text-3);
      padding: 0 24px;
      position: relative;
      white-space: nowrap;
      transition: color 0.2s ease;
      cursor: default;
    }
    .title-item:hover { color: var(--text-1); }
    .title-item.bright:hover { color: #fff; }
    .title-item.red { color: var(--red); }
    .title-item.red:hover { color: #cc0000; }
    .hero-actions {
      display: flex;
      gap: 12px;
      position: relative;
      z-index: 2;
      flex-wrap: wrap;
      justify-content: center;
    }
    .btn {
      font-family: 'DM Mono', monospace;
      font-size: 20px;
      font-weight: 300;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      padding: 12px 28px;
      cursor: pointer;
      border: 1px solid #222;
      color: var(--text-3);
      background: transparent;
      text-decoration: none;
      position: relative;
      overflow: hidden;
      transition: color 0.3s ease, border-color 0.3s ease;
      z-index: 0;
    }
    .btn::before {
      content: '';
      position: absolute;
      bottom: 0; left: 0;
      width: 100%; height: 0;
      background: #222;
      transition: height 0.3s ease;
      z-index: -1;
    }
    .btn:hover::before { height: 100%; }
    .btn:hover { color: var(--text-1); border-color: #444; }
    .btn.primary::before { background: var(--red); }
    .btn.primary { border-color: var(--red); color: var(--red); }
    .btn.primary:hover { color: var(--text-1); }

    /* ── RESPONSIVE ── */
    @media (max-width: 1024px) {
      .hero { padding: 60px 32px 48px; height: auto; min-height: calc(95vh - 64px - 70px); }
    }
    @media (max-width: 640px) {
      .hero { padding: 40px 20px; height: auto; min-height: calc(100svh - 100px); }
      .hero-name { margin-bottom: 4vh; }
      .hero-rule { max-width: 100%; }
      .hero-titles { flex-direction: column; align-items: center; gap: 12px; }
      .title-item { padding: 0; font-size: 11px; white-space: normal; text-align: center; }
      .title-item::after { display: none; }
      .hero-actions { flex-direction: column; align-items: center; width: 100%; }
      .btn { width: 100%; text-align: center; }
      .hero-eyebrow { font-size: 9px; letter-spacing: 0.08em; }
    }

    /* ── ANIMATION INITIAL STATES ── */
    .hero-eyebrow,
    .hero-name,
    .hero-rule,
    .hero-titles,
    .hero-actions {
      opacity: 0;
      transform: translateY(20px);
    }
  </style>

  <section class="hero">
    <p class="hero-eyebrow">Chemical Engineering · University of Saskatchewan · 2nd Year</p>

    <h1 class="hero-name">
      <span>Evan</span>
      <span>Johnson</span>
    </h1>

    <div class="hero-rule"></div>

    <div class="hero-titles">
      <span class="title-item bright">Graham Construction</span>
      <span class="title-item">Student Project Coordinator</span>
      <span class="title-item red">3× Hackathon Winner</span>
      <span class="title-item">Future Nuclear Industry Professional</span>
      <span class="title-item">Saskatoon, SK</span>
    </div>

    <div class="hero-actions">
      <a href="/Evan%20Johnson%20Resume%20(2026-03-30).pdf" class="btn primary" target="_blank" rel="noopener">View Resume</a>
      <a href="/contact" class="btn">Get in Touch</a>
      <a href="https://www.linkedin.com/in/evan-johnson-sk" class="btn" target="_blank">LinkedIn</a>
      <a href="/currently" class="btn">Current events</a>
      <a href="/about" class="btn">Get to know me</a>
    </div>
  </section>

  <script is:inline>
    window.onload = function() {
      var elements = [
        '.hero-eyebrow',
        '.hero-name',
        '.hero-rule',
        '.hero-titles',
        '.hero-actions'
      ];
      elements.forEach(function(selector, index) {
        var el = document.querySelector(selector);
        if (el) {
          setTimeout(function() {
            el.style.transition = 'opacity 0.8s ease, transform 0.8s ease';
            el.style.opacity = '1';
            el.style.transform = 'translateY(0)';
          }, index * 300);
        }
      });
    }
  </script>

</Layout>
