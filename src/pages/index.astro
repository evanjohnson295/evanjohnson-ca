<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Evan Johnson — evanjohnson.ca</title>
  <link href="https://fonts.googleapis.com/css2?family=Michroma&family=Exo+2:wght@300;400;500&display=swap" rel="stylesheet" />
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }

    .stripes { display: block; width: 100%; line-height: 0; font-size: 0; }
    .stripes div { display: block; height: 4px; width: 100%; }
    .s-red { background: #e32; }
    .s-orange { background: #f80; }
    .s-cyan { background: #0cf; }

    body { font-family: 'Exo 2', sans-serif; }
    .hp-root { background: #1a1535; }

    .hp-nav { background: #f5f5f0; display: flex; align-items: center; justify-content: center; padding: 0 28px; height: 52px; gap: 0; }
    .hp-nav-link { font-family: 'Exo 2', sans-serif; font-size: 11px; font-weight: 500; color: #1a1535; letter-spacing: 0.12em; cursor: pointer; text-transform: uppercase; flex: 1; text-align: center; }

    .hp-hero { background: #f5f5f0; padding: 48px 32px 28px; }
    .hp-hero-tag { font-family: 'Exo 2', sans-serif; font-size: 10px; font-weight: 500; letter-spacing: 0.18em; color: #888; text-transform: uppercase; margin-bottom: 16px; display: flex; align-items: center; gap: 8px; }
    .hp-hero-tag::before { content: ''; display: block; width: 24px; height: 2px; background: #e32; }
    .hp-hero-name { font-family: 'Michroma', monospace; font-size: 42px; color: #12102a; line-height: 1.1; margin: 0 0 6px; }
    .hp-hero-sub { font-family: 'Exo 2', sans-serif; font-size: 14px; color: #555; font-weight: 300; letter-spacing: 0.06em; margin-bottom: 24px; }
    .hp-badges { display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 32px; }
    .hp-badge { font-family: 'Exo 2', sans-serif; font-size: 10px; font-weight: 500; letter-spacing: 0.1em; text-transform: uppercase; padding: 5px 12px; border: 1.5px solid #1a1535; color: #1a1535; background: transparent; }
    .hp-badge.accent { background: #1a1535; color: #f5f5f0; }
    .hp-cta-row { display: flex; gap: 12px; margin-bottom: 28px; }
    .hp-btn { font-family: 'Exo 2', sans-serif; font-size: 11px; font-weight: 500; letter-spacing: 0.12em; text-transform: uppercase; padding: 10px 22px; cursor: pointer; border: 1.5px solid #1a1535; }
    .hp-btn.primary { background: #1a1535; color: #f5f5f0; }
    .hp-btn.secondary { background: transparent; color: #1a1535; }
    .hp-stat-row { display: flex; gap: 24px; }
    .hp-stat-num { font-family: 'Michroma', monospace; font-size: 22px; color: #0cf; }
    .hp-stat-lbl { font-family: 'Exo 2', sans-serif; font-size: 9px; color: #9a96b8; letter-spacing: 0.12em; text-transform: uppercase; margin-top: 2px; }

    .hp-content { background: #12102a; display: grid; grid-template-columns: 1fr 1fr; }
    .hp-panel { padding: 28px; border-right: 1.5px solid #2a2448; border-top: 1.5px solid #2a2448; }
    .hp-panel:nth-child(even) { border-right: none; }
    .hp-panel-label { font-family: 'Exo 2', sans-serif; font-size: 9px; font-weight: 500; letter-spacing: 0.2em; text-transform: uppercase; color: #f80; margin-bottom: 14px; display: flex; align-items: center; gap: 8px; }
    .hp-panel-label::before { content: ''; display: block; width: 12px; height: 1.5px; background: #f80; }
    .hp-panel-text { font-family: 'Exo 2', sans-serif; font-size: 12px; color: #9a96b8; line-height: 1.7; font-weight: 300; }
    .hp-hack-row { display: flex; flex-direction: column; gap: 10px; }
    .hp-hack-item { display: flex; align-items: center; gap: 12px; }
    .hp-hack-rank { font-family: 'Michroma', monospace; font-size: 11px; color: #f80; min-width: 20px; }
    .hp-hack-name { font-family: 'Exo 2', sans-serif; font-size: 12px; color: #f5f5f0; font-weight: 400; }
    .hp-hack-pos { font-family: 'Exo 2', sans-serif; font-size: 10px; color: #9a96b8; margin-left: auto; letter-spacing: 0.08em; white-space: nowrap; }
    .hp-skills-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; }
    .hp-skill-pill { font-family: 'Exo 2', sans-serif; font-size: 10px; color: #9a96b8; font-weight: 400; padding: 6px 10px; border: 1px solid #2a2448; letter-spacing: 0.06em; }

    .hp-footer { background: #f5f5f0; padding: 16px 32px; display: flex; align-items: center; justify-content: space-between; border-top: 1.5px solid #ddd; }
    .hp-footer-name { font-family: 'Michroma', monospace; font-size: 12px; color: #1a1535; }
    .hp-footer-links { display: flex; gap: 20px; }
    .hp-footer-link { font-family: 'Exo 2', sans-serif; font-size: 10px; color: #888; letter-spacing: 0.1em; text-transform: uppercase; cursor: pointer; }
    .section-stripe { height: 3px; background: linear-gradient(to right, #e32 33%, #f80 33% 66%, #0cf 66%); }
  </style>
</head>
