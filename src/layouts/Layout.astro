---
// Layout.astro — shared layout for all pages
// src/layouts/Layout.astro
const { title, description, activePage } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/x-icon" href="/EJ_favicon.png" />
    <title>{title}</title>
    <link href="https://fonts.googleapis.com/css2?family=Michroma&family=Exo+2:wght@300;400;500;600&family=DM+Mono:wght@300;400&display=swap" rel="stylesheet" />
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
        html { scroll-behavior: smooth; }
        body { font-family: 'Exo 2', sans-serif; background: #0a0a0a; color: #e8e8e8; }
        ul, ol, li { list-style: none; margin: 0; padding: 0; }

        :root {
            --black:     #0a0a0a;
            --black-3:   #060606;
            --surface-2: #161616;
            --border-2:  #1e1e1e;
            --text-1:    #e8e8e8;
            --text-3:    #999;
            --text-4:    #888;
            --text-5:    #777;
            --red:       #8b0000;
        }

        .nav {
            background: var(--black);
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 60px;
            height: 64px;
            border-bottom: 1px solid var(--border-2);
            position: sticky;
            top: 0;
            z-index: 100;
        }
        .nav-logo {
            font-family: 'Michroma', monospace;
            font-size: 15px;
            color: var(--text-1);
            letter-spacing: 0.06em;
            text-decoration: none;
            position: relative;
            padding-bottom: 4px;
        }
        .nav-logo::after {
            content: '';
            position: absolute;
            bottom: 0; left: 0;
            width: 0; height: 1px;
            background: var(--red);
            transition: width 0.3s ease;
        }
        .nav-logo:hover::after { width: 100%; }
        .nav-links { display: flex; gap: 40px; list-style: none; }
        .nav-links li { list-style: none; }
        .nav-links a {
            font-family: 'DM Mono', monospace;
            font-size: 10px;
            font-weight: 300;
            color: var(--text-3);
            letter-spacing: 0.18em;
            text-decoration: none;
            text-transform: uppercase;
            transition: color 0.2s ease;
            position: relative;
            padding-bottom: 4px;
        }
        .nav-links a::after {
            content: '';
            position: absolute;
            bottom: 0; left: 0;
            width: 0; height: 1px;
            background: var(--red);
            transition: width 0.3s ease;
        }
        .nav-links a:hover::after { width: 100%; }
        .nav-links a.active { color: var(--text-1); }
        .nav-links a.active::after { width: 100%; }

        .page-main {
            background: var(--black);
            height: calc(100vh - 64px - 70px);
            position: relative;
            overflow: hidden;
        }
        .hero-grid {
            position: absolute;
            inset: 0;
            background-image:
                    linear-gradient(var(--surface-2) 1px, transparent 1px),
                    linear-gradient(90deg, var(--surface-2) 1px, transparent 1px);
            background-size: 60px 60px;
            opacity: 0;
            pointer-events: none;
            animation: gridFadeIn 2.5s ease forwards;
            animation-delay: 0.5s;
        }
        @keyframes gridFadeIn {
            from { opacity: 0; }
            to   { opacity: 0.6; }
        }
        .hero-grid-fade {
            position: absolute;
            inset: 0;
            background: radial-gradient(ellipse at center, transparent 30%, var(--black) 75%);
            pointer-events: none;
            z-index: 1;
        }

        .footer {
            background: var(--black-3);
            padding: 24px 60px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            border-top: 1px solid var(--surface-2);
        }
        .footer-name { font-family: 'Michroma', monospace; font-size: 13px; color: #777; letter-spacing: 0.06em; }
        .footer-links { display: flex; gap: 32px; }
        .footer-link {
            font-family: 'DM Mono', monospace;
            font-size: 9px;
            color: var(--text-5);
            letter-spacing: 0.14em;
            text-transform: uppercase;
            text-decoration: none;
            transition: color 0.2s;
        }
        .footer-link:hover { color: var(--text-3); }
        .footer-loc { font-family: 'DM Mono', monospace; font-size: 9px; color: #777; letter-spacing: 0.1em; }

        @media (max-width: 1024px) {
            .nav { padding: 0 32px; }
            .page-main { height: auto; min-height: calc(100vh - 64px - 70px); }
            .footer { padding: 20px 32px; flex-wrap: wrap; gap: 12px; }
        }
        @media (max-width: 640px) {
            .nav { padding: 12px 20px; height: auto; min-height: 64px; flex-wrap: wrap; gap: 8px; }
            .nav-links { gap: 16px; flex-wrap: wrap; justify-content: center; }
            .page-main { min-height: calc(100svh - 100px); }
            .footer { flex-direction: column; align-items: flex-start; padding: 20px; gap: 10px; }
            .footer-links { flex-direction: column; gap: 8px; }
        }
    </style>
</head>
<body>

<nav class="nav">
    <a href="/" class="nav-logo">Evan Johnson</a>
    <ul class="nav-links">
        <li><a href="/about"     class={activePage === 'about'     ? 'active' : ''}>About</a></li>
        <li><a href="/currently" class={activePage === 'currently' ? 'active' : ''}>Currently</a></li>
        <li><a href="/projects"  class={activePage === 'projects'  ? 'active' : ''}>Projects</a></li>
        <li><a href="/experience" class={activePage === 'experience' ? 'active' : ''}>Experience</a></li>
        <li><a href="/skills"    class={activePage === 'skills'    ? 'active' : ''}>Skills</a></li>
        <li><a href="/contact"   class={activePage === 'contact'   ? 'active' : ''}>Contact</a></li>
    </ul>
</nav>

<main class="page-main">
    <div class="hero-grid"></div>
    <div class="hero-grid-fade"></div>
    <slot />
</main>

<footer class="footer">
    <span class="footer-name">Evan Johnson</span>
    <div class="footer-links">
        <a href="https://www.linkedin.com/in/evan-johnson-sk" class="footer-link" target="_blank">www.linkedin.com/in/evan-johnson-sk</a>
        <a href="mailto:evanjohnson295@gmail.com" class="footer-link">evanjohnson295@gmail.com</a>
        <a href="https://evanjohnson.ca" class="footer-link">evanjohnson.ca</a>
    </div>
    <span class="footer-loc">Saskatoon, Saskatchewan</span>
</footer>

</body>
</html>
